{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "invoker": "private",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix functions run lint",
        "npm --prefix functions run build"
      ]
    }
  ],
  "firestore": {
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma", "value": "no-cache" },
          { "key": "Expires", "value": "0" },
          { "key": "Service-Worker-Allowed", "value": "/" }
        ]
      },
      {
        "source": "/manifest.json",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma", "value": "no-cache" },
          { "key": "Expires", "value": "0" }
        ]
      },
      {
        "source": "/icons/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "/core/**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma", "value": "no-cache" },
          { "key": "Expires", "value": "0" }
        ]
      },
      {
        "source": "/modules/**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma", "value": "no-cache" },
          { "key": "Expires", "value": "0" }
        ]
      },
      {
        "source": "/styles/**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma", "value": "no-cache" },
          { "key": "Expires", "value": "0" }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma", "value": "no-cache" },
          { "key": "Expires", "value": "0" }
        ]
      },
      {
        "source": "/api/**",
        "headers": [
          { "key": "Access-Control-Allow-Origin", "value": "*" },
          { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
          { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/setup",
        "function": {
          "functionId": "getSetup",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/admin/setup",
        "function": {
          "functionId": "adminPutSetup",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/register",
        "function": {
          "functionId": "registerUser",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/gear/kayaks",
        "function": {
          "functionId": "getGearKayaks",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/gear/items",
        "function": {
          "functionId": "getGearItems",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/gear/my-reservations",
        "function": {
          "functionId": "getGearMyReservations",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/gear/reservations/create",
        "function": {
          "functionId": "createGearReservation",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/gear/reservations/update",
        "function": {
          "functionId": "updateGearReservation",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/gear/reservations/cancel",
        "function": {
          "functionId": "cancelGearReservation",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/gear/favorites",
        "function": {
          "functionId": "getGearFavorites",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/gear/favorites/toggle",
        "function": {
          "functionId": "gearFavoriteToggle",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/godzinki",
        "function": {
          "functionId": "getGodzinki",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/godzinki/submit",
        "function": {
          "functionId": "submitGodzinki",
          "region": "us-central1"
        }
      }
    ]
  }
}
